/* Create table with actors' personal information */
CREATE TABLE actors (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    first_name TEXT,
    last_name TEXT,
    birthyear INTEGER,
    spouse_id INTEGER);
    
