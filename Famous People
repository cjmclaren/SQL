/* Write a query showing the actors who are married next to the name of their spouses, and concatenate the spouse name without using the CONCAT operator */

SELECT a.first_name, a.last_name,
  b.first_name || ' ' || b.last_name AS "spouse"
FROM actors AS a
INNER JOIN actors AS b
ON a.spouse_id = b.id;
